      "label": "Non-Western Art",
      "note": "Two courses: Latin American, Islamic, African, South Asian, Chinese, or Japanese art"
    },
    "fnar-modern-western": {
      "creditsRequired": 3,
      "label": "Modern Art and Western Traditions",
      "note": "One course such as Women/Art/Society, Paris in the Nineteenth Century, or Contemporary Art"
    },
